# BNI/BIONS Sentiment Analysis - Collector Config
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=bions_sentiment

# YouTube (optional, enables comments beyond RSS)
YOUTUBE_API_KEY=*** X/Twitter (required for X collector)
X_BEARER_TOKEN=*** Search queries for mentions
X_SE...IONS lang:id -is:retweet,BNI Sekuritas lang:id -is:retweet
X_OFFICIAL_USERNAMES=BNI1946,bnisekuritas46

# TikTok Research API (required for official TikTok collector)
TIKTOK_RESEARCH_ACCESS_TOKEN=*** TikTok public oembed (alternative)
TIKTOK_TARGET_URLS=

# Instagram Graph API (required for Instagram collector)
INSTAGRAM_GRAPH_ACCESS_TOKEN=*** Threads Graph API
THREADS_ACCESS_TOKEN=*** Stockbit public scrape
STOCKBIT_TARGET_URLS=

# App Store / Google Play (no tokens needed)
APP_STORE_APP_ID=6736508566
GOOGLE_PLAY_PACKAGE_ID=id.bions.bnis.android
